// Creates trail effects or bursts when clicking anywhere on the screen
document.addEventListener('click', (e) => {
    const burst = document.createElement('div');
    burst.style.position = 'absolute';
    burst.style.left = `${e.clientX}px`;
    burst.style.top = `${e.clientY}px`;
    burst.style.width = '20px';
    burst.style.height = '20px';
    burst.style.backgroundColor = '#ffffff';
    burst.style.borderRadius = '50%';
    burst.style.transform = 'translate(-50%, -50%)';
    burst.style.pointerEvents = 'none';
    burst.style.transition = 'all 0.6s ease-out';
    
    document.body.appendChild(burst);
    
    // Trigger animation frame expansion and fade out
    setTimeout(() => {
        burst.style.width = '100px';
        burst.style.height = '100px';
        burst.style.opacity = '0';
    }, 10);
    
    setTimeout(() => burst.remove(), 600);
});

